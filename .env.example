ZEPHYR_API_TOKEN=""
# Zephyr Scale project (optional; defaults to config/testing-repos.json)
# ZEPHYR_PROJECT_KEY=CW

# Git repos (override paths in config/testing-repos.json)
# REFORMERS_REPO_PATH=/path/to/reformers.content-manager-client
# REFORMERS_SERVICE_REPO_PATH=/path/to/reformers.content-manager-service
# REFORMERS_SERVICE_GIT_BRANCH=main

# JUnit → Zephyr executions (scripts/report-junit-to-zephyr.js)
# ZEPHYR_TEST_CYCLE_KEY=CW-R42

# GitHub Actions (workflow .github/workflows/zephyr-junit-orchestrated.yml): set as repo secrets on autotest, not in .env
# REFORMERS_GITHUB_PAT — HTTPS clone (company account; fine-grained read both repos + SSO, or classic repo scope)
# REFORMERS_GITHUB_SSH_KEY — optional SSH clone; private key; public key on company account (user key, both repos)
# SIGNIFY_NPM_TOKEN — optional; Signify npm registry for client npm ci on hosted runners

# When true, POST /api/snapshot also runs dotnet test with XPlat code coverage on the service (slow).
# SNAPSHOT_INCLUDE_DOTNET_COVERAGE=true
