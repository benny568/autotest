{
  "name": "autotest-report-generator",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "snapshot": "mkdir -p logs && node scripts/scheduled-snapshot.js >> logs/cron.log 2>&1 && echo 'Log written to logs/cron.log'",
    "quality-graph": "(node scripts/fetch-defects-for-quality-graph.js || true) && node scripts/build-quality-graph-from-csv.js data/mcp-defects-cw-reformers.json data/mcp-defects-2026.json",
    "zephyr:sync": "node scripts/sync-tests-to-zephyr.js",
    "zephyr:sync:execute": "node scripts/sync-tests-to-zephyr.js --execute",
    "zephyr:sync:dotnet": "node scripts/sync-dotnet-tests-to-zephyr.js",
    "zephyr:sync:dotnet:execute": "node scripts/sync-dotnet-tests-to-zephyr.js --execute",
    "zephyr:report-junit": "node scripts/report-junit-to-zephyr.js",
    "dotnet:discover": "node scripts/discover-dotnet-tests.js",
    "testing:weekly-delta": "node scripts/weekly-testing-delta.js",
    "setup-cron": "bash scripts/setup-cron.sh",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop autotest-server",
    "pm2:restart": "pm2 restart autotest-server",
    "pm2:logs": "pm2 logs autotest-server",
    "pm2:status": "pm2 status",
    "setup-pm2": "bash scripts/setup-pm2.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
